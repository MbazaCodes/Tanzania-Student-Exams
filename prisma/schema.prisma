// ExamHub — Papers Library + Exam management schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  role            String       @default("student") // student | teacher | school_admin | super_admin
  schoolId        String?
  school          School?      @relation(fields: [schoolId], references: [id])
  uploadedPapers  Paper[]
  createdExams    Exam[]
  studentSubs     Submission[] @relation("StudentSubmissions")
  reviewedSubs    Submission[] @relation("ReviewerSubmissions")
  createdAt       DateTime     @default(now())
}

model School {
  id        String   @id @default(cuid())
  name      String
  region    String
  plan      String   @default("free") // free | premium | enterprise
  users     User[]
  papers    Paper[]
  exams     Exam[]
  createdAt DateTime @default(now())
}

model Paper {
  id           String   @id @default(cuid())
  title        String
  subject      String
  level        String   // standard_4 | standard_7 | form_2 | form_4 | form_6
  year         Int
  type         String   @default("necta") // necta | mock | school | regional | pre_national
  status       String   @default("draft") // draft | published | archived
  fileName     String?
  fileSize     Int?
  description  String?
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  exam         Exam?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Exam {
  id           String       @id @default(cuid())
  title        String
  subject      String
  level        String
  durationMins Int
  totalMarks   Int          @default(0)
  status       String       @default("draft") // draft | published | closed
  description  String?
  paperId      String?      @unique
  paper        Paper?       @relation(fields: [paperId], references: [id])
  createdById  String
  createdBy    User         @relation(fields: [createdById], references: [id])
  schoolId     String?
  school       School?      @relation(fields: [schoolId], references: [id])
  questions    Question[]
  submissions  Submission[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Question {
  id            String   @id @default(cuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  type          String   // mcq | truefalse | short | essay
  text          String
  options       String   // JSON array string for mcq: '["a","b","c","d"]'
  correctAnswer String   // mcq: index; truefalse: "true"/"false"; short/essay: reference answer
  explanation   String?
  marks         Int      @default(1)
  difficulty    String   @default("medium") // easy | medium | hard
  order         Int      @default(0)
  answers       Answer[]
  createdAt     DateTime @default(now())
}

model Submission {
  id           String   @id @default(cuid())
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id])
  studentId    String
  student      User     @relation("StudentSubmissions", fields: [studentId], references: [id])
  score        Int?
  percentage   Float?
  grade        String? // A | B | C | D | F
  status       String   @default("submitted") // submitted | auto_marked | reviewed | published
  reviewedById String?
  reviewedBy   User?    @relation("ReviewerSubmissions", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  submittedAt  DateTime @default(now())
  answers      Answer[]
  createdAt    DateTime @default(now())
}

model Answer {
  id            String     @id @default(cuid())
  submissionId  String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question   @relation(fields: [questionId], references: [id])
  answer        String
  isCorrect     Boolean?
  marksAwarded  Int        @default(0)
  feedback      String?
  createdAt     DateTime   @default(now())
}
